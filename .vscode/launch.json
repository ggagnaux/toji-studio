{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Toji Backend",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/public/server/src/server.js",
      "cwd": "${workspaceFolder}/public/server",
      "envFile": "${workspaceFolder}/public/server/.env",
      "console": "integratedTerminal",
      "restart": true,
      "runtimeArgs": ["--watch"]
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Attach to Running Node Process",
      "port": 9229,
      "skipFiles": ["<node_internals>/**"],
      "restart": true
    }
  ]
}
